# ========== GLM API 配置 ==========
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/anthropic
GLM_MODEL=GLM-5.2

# ========== 飞书应用配置 (4个应用) ==========

# 产品需求AI
FEISHU_PM_APP_ID=cli_xxxxxxxxxx1
FEISHU_PM_APP_SECRET=your_pm_app_secret

# UI设计AI
FEISHU_UI_APP_ID=cli_xxxxxxxxxx2
FEISHU_UI_APP_SECRET=your_ui_app_secret

# 编码AI
FEISHU_CODER_APP_ID=cli_xxxxxxxxxx3
FEISHU_CODER_APP_SECRET=your_coder_app_secret

# 总负责AI
FEISHU_LEAD_APP_ID=cli_xxxxxxxxxx4
FEISHU_LEAD_APP_SECRET=your_lead_app_secret

# ========== 飞书事件订阅加密(可选) ==========
# 如果在飞书后台设置了 Encrypt Key,填这里
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
