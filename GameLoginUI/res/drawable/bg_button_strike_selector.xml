<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_button_strike_selector.xml
    Selector for the DEPLOY button: shows a dimmed/pressed variant when the
    button is pressed, otherwise the normal strike gradient. Pair with a
    stateListAnimator for elevation on API 21+.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true" android:drawable="@drawable/bg_button_strike_pressed" />
    <item android:state_enabled="false" android:drawable="@drawable/bg_button_strike_disabled" />
    <item android:drawable="@drawable/bg_button_strike" />
</selector>
