<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_input_tactical_focus.xml
    Focused variant of the input background: border switches to tactical red
    and the accent tick brightens, giving clear focus affordance.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="280dp"
    android:height="52dp"
    android:viewportWidth="280"
    android:viewportHeight="52">

    <path
        android:name="fill"
        android:fillColor="@color/input_bg"
        android:pathData="M 10,0 L 270,0 L 280,10 L 280,42 L 270,52 L 10,52 L 0,42 L 0,10 Z" />

    <path
        android:name="border"
        android:strokeColor="@color/input_border_focus"
        android:strokeWidth="2"
        android:fillColor="#00000000"
        android:pathData="M 10,0 L 270,0 L 280,10 L 280,42 L 270,52 L 10,52 L 0,42 L 0,10 Z" />

    <path
        android:name="accent_tick"
        android:strokeColor="@color/tactical_red_light"
        android:strokeWidth="3"
        android:fillColor="#00000000"
        android:pathData="M 6,18 L 6,34" />

</vector>
