<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_input_tactical_selector.xml
    State-list selector that swaps the input chamfered background between the
    default (metal gray) and focused (tactical red) variants.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:drawable="@drawable/bg_input_tactical_focus" />
    <item android:drawable="@drawable/bg_input_tactical" />
</selector>
